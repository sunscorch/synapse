				"source": [
					"%%spark\r\n",
					" \r\n",
					" \r\n",
					" val checkIpAddress = udf(() => {\r\n",
					"      val executorIp = java.net.InetAddress.getLocalHost.getHostAddress\r\n",
					"\r\n",
					"      // Pattern matching to handle IP check\r\n",
					"      executorIp match {\r\n",
					"        case \"10.0.46.0\"  => throw new RuntimeException(s\"Blocked IP detected: $executorIp\")\r\n",
					"        case _ => \r\n",
					"          // Sleep for 1 second if the IP does not match\r\n",
					"          Thread.sleep(30000)\r\n",
					"          executorIp\r\n",
					"      }\r\n",
					"    })\r\n",
					"\r\n",
					"    // Create a DataFrame with numbers from 1 to 100\r\n",
					"    import spark.implicits._\r\n",
					"    val df = Seq(1 to 100: _*).toDF(\"value\")\r\n",
					"    val resultDf = df.withColumn(\"executor_ip\", checkIpAddress())\r\n",
					"      // Show the results\r\n",
					"    resultDf.show(truncate = false)\r\n",
					""
				],
				"execution_count": 6
			},
